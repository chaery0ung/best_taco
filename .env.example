# Local dev defaults to sqlite:///./dev.db if unset.
DATABASE_URL=postgresql://user:password@localhost:5432/skinwatch

# Used to sign auth JWTs. Render's render.yaml auto-generates this in production.
JWT_SECRET=change-me-in-production

# Vertex AI classification endpoint. Without these, /api/lesions/{id}/captures
# returns 503 instead of calling the real model.
VERTEX_PROJECT=94890171980
VERTEX_ENDPOINT_ID=6896410158050574336
VERTEX_LOCATION=us-central1

# Path to a GCP service account key JSON with the Vertex AI User role.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
